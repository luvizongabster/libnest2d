# Digital Ocean – variáveis de ambiente
# Copie para .env e preencha (não commite .env com chaves).
# Uso: docker compose -f docker-compose.yml -f docker-compose.do.yml up -d
#      ou com Spaces: docker compose -f docker-compose.do.spaces.yml up -d

# --- Opção A: MinIO no Droplet (padrão) ---
# Não defina S3_ENDPOINT/S3_BUCKET para usar os defaults do compose (MinIO local).
# Ou defina para sobrescrever:
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=nest-results
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# --- Opção B: Digital Ocean Spaces (S3-compatível) ---
# Crie um Space no painel DO e gere uma Spaces API key.
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_BUCKET=nest-results
# AWS_ACCESS_KEY_ID=<SPACES_ACCESS_KEY>
# AWS_SECRET_ACCESS_KEY=<SPACES_SECRET_KEY>
# AWS_DEFAULT_REGION=us-east-1
# Para usar Spaces, rode com docker-compose.do.spaces.yml (sem container MinIO)
# e defina SKIP_S3_INIT=1 (o bucket/Space é criado no painel DO).

# --- Comum ---
# TABLE_NAME=nest_jobs
# QUEUE_NAME=nest-jobs
# PRESIGNED_EXPIRY=600
# ENGINE_TIMEOUT=20
